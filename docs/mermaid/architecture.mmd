flowchart TB
    subgraph API["Public API Surface"]
        OPTS["BufferManagerOptions"]
        BMAPI["BufferManager"]
        BH["BufferHandle"]
        SNAP["BufferPoolSnapshot Export"]
    end

    subgraph Engine["Core Cache Engine"]
        FMP["FrameMemoryPool"]
        PT["Striped Page Table"]
        MISS["Miss Coordinator<br/>MissState shards"]
        BD["BufferDescriptor Array"]
        CL["Per-frame Content Latch"]
        FLUSH["Async Flush Scheduler"]
        FGQ["Foreground Flush Queue"]
        BGQ["Background Flush Queue"]
        FW["Flush Worker(s)"]
        CLEAN["Background Cleaner"]
        DISP["Completion Dispatcher"]
        RP["Replacer Interface"]
        CLOCK["ClockReplacer"]
        LRU["LruReplacer"]
        LRUK["LruKReplacer"]
    end

    subgraph Storage["Storage Backend Layer"]
        DB["DiskBackend"]
        POSIX["PosixDiskBackend<br/>fallback path"]
        URING["IoUringDiskBackend<br/>native Linux path"]
        MEDIA["Page Files / Storage Media"]
    end

    subgraph Observe["In-process Observation"]
        TS["TelemetrySink"]
        FAST["Fast-path Counters"]
        CTS["CounterTelemetrySink"]
        NTS["NoOpTelemetrySink"]
        FUTURE["Future: Shared Memory Telemetry Export"]
    end

    OPTS --> BMAPI
    BMAPI --> BH
    BMAPI --> SNAP

    BMAPI --> FMP
    BMAPI --> PT
    BMAPI --> MISS
    BMAPI --> BD
    BMAPI --> FLUSH
    BMAPI --> CLEAN
    BMAPI --> DISP
    BMAPI --> RP
    BMAPI --> DB
    BMAPI --> TS

    BH --> CL
    BD --> CL
    BD --> SNAP

    FLUSH --> FGQ
    FLUSH --> BGQ
    FGQ --> FW
    BGQ --> FW
    CLEAN --> BGQ
    DISP --> MISS
    DISP --> FLUSH

    RP --> CLOCK
    RP --> LRU
    RP --> LRUK

    DB --> POSIX
    DB --> URING
    POSIX --> MEDIA
    URING --> MEDIA
    FW --> DB
    DISP --> DB
    MISS --> DB

    TS --> FAST
    TS --> CTS
    TS --> NTS
    SNAP -.-> FUTURE
    TS -.-> FUTURE

    classDef future stroke-dasharray: 5 5;
    class FUTURE future;
