        TS["TelemetrySink"]
        FAST["Fast-path Counters"]
        CTS["CounterTelemetrySink"]
        NTS["NoOpTelemetrySink"]
        FUTURE_EXP["Future: Shared Memory Telemetry Pipeline"]
    end

