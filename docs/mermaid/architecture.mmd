        CL["Per-page Content Latch"]
        FLUSH["Async Flush Scheduler"]
        FGQ["Foreground Flush Queue"]
        BGQ["Background Flush Queue"]
        FW["Flush Worker(s)"]
        CLEAN["Background Cleaner"]
        DISP["Completion Dispatcher"]
        RP["Replacer Interface"]
        CLOCK["ClockReplacer"]
        LRU["LruReplacer"]
        LRUK["LruKReplacer"]
    end

    subgraph Storage["Storage Backend Layer"]
        FACTORY["DiskBackendFactory"]
        DB["DiskBackend"]
        POSIX["PosixDiskBackend<br/>fallback path"]
        URING["IoUringDiskBackend<br/>native Linux path"]
        MEDIA["Page Files / Storage Media"]
    end

